{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "lib": [
            "ESNext",
            "DOM"
        ],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@/": [
                "src/index.ts"
            ]
        }
    },
    "include": [
        "src",
        "tests"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}